# "Preview" token from your Storyblok space.
# Storyblok > Settings > Access Tokens.
STORYBLOK_TOKEN=

# Web3Forms access key for the contact form (free).
# https://web3forms.com -> give an email, get a key, that's it.
# PUBLIC_ variables are exposed to the browser (intended here).
PUBLIC_WEB3FORMS_KEY=
