---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings } from '../lib/site';

const settings = await getSettings('fr');

// The form posts to a form-handling service (Web3Forms by default).
// No install, no backend: the request goes out via client-side fetch.
// Set PUBLIC_WEB3FORMS_KEY in .env (see README for the Resend option
// "send from your own domain").
const formEndpoint = 'https://api.web3forms.com/submit';
// Read at build time (frontmatter); injected into the inline script via define:vars.
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<BaseLayout title="Contact">
  <section class="wrap section">
    <p class="eyebrow">Contact</p>
    <h2 style="font-size: var(--step-2); margin-top: 1rem; max-width: 16ch;">
      Un projet en tête ? Parlons-en.
    </h2>

    <div class="project-body" style="padding-top: 3rem;">
      <form id="contact-form" novalidate>
        <!-- anti-bot honeypot: invisible to humans -->
        <input
          type="checkbox"
          name="botcheck"
          tabindex="-1"
          autocomplete="off"
          style="position:absolute;left:-9999px"
          aria-hidden="true"
        />
        <div class="field">
          <label for="name">Nom</label>
          <input id="name" name="name" type="text" required />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required />
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button class="btn" type="submit">Envoyer</button>
        <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
      </form>

      <aside>
        <p class="eyebrow">Direct</p>
        <p style="margin-top: 0.75rem;">
          <a href={`mailto:${settings.email}`}>{settings.email}</a>
        </p>
        <p style="margin-top: 1.5rem;" class="eyebrow">Basé à</p>
        <p style="margin-top: 0.75rem; color: var(--ink-soft);">{settings.location}</p>
      </aside>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ formEndpoint, accessKey }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!accessKey) {
      status.textContent =
        'Formulaire pas encore configuré (PUBLIC_WEB3FORMS_KEY manquant).';
      status.dataset.state = 'error';
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    if (data.botcheck) return; // bot detected

    status.textContent = 'Envoi en cours...';
    status.dataset.state = 'pending';

    try {
      const response = await fetch(formEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          access_key: accessKey,
          subject: 'Nouveau message via gibbonsstudio.net',
          ...data,
        }),
      });
      const result = await response.json();
      if (result.success) {
        status.textContent = 'Merci, message envoyé. Je reviens vers toi vite.';
        status.dataset.state = 'success';
        form.reset();
      } else {
        throw new Error(result.message || 'Erreur');
      }
    } catch (error) {
      status.textContent = "Oups, l'envoi a échoué. Réessaie ou écris-moi en direct.";
      status.dataset.state = 'error';
    }
  });
</script>
