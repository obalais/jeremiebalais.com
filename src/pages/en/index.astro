---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/WorkCard.astro';
import Filters from '../../components/Filters.astro';
import { getWorks, CATEGORY_ORDER } from '../../lib/works';

// Homepage = works (EN). Storyblok content in English (FR fallback if not translated).
const works = await getWorks('en');
const present = new Set(works.flatMap((work) => work.categories));
const categories = CATEGORY_ORDER.filter((category) => present.has(category));
---

<BaseLayout title="Works">
  <section class="wrap section section--flush-top">
    <Filters categories={categories} variant="text" allLabel="All" lang="en" />
    <div class="works-grid">
      {works.map((work) => <WorkCard work={work} base="/en" />)}
    </div>
  </section>
</BaseLayout>
